# ==============================================================================
# Required — the app will not start without these
# ==============================================================================

# PostgreSQL connection string
# For local development: postgres://user:password@localhost:5432/giselle
# @see https://vercel.com/docs/storage/vercel-postgres#getting-started
POSTGRES_URL=

# GitHub App credentials (all five are validated at boot)
# @see https://docs.github.com/en/apps/creating-github-apps
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_WEBHOOK_SECRET=

# At least one AI provider API key is needed to use text generation
# OpenAI API https://openai.com/index/openai-api/
# @see https://platform.openai.com/docs/quickstart
OPENAI_API_KEY=

# ==============================================================================
# Optional — features will degrade gracefully without these
# ==============================================================================

# Additional AI providers
# ANTHROPIC_API_KEY=
# GOOGLE_AI_API_KEY=

# Additional Postgres connection variants (Vercel Postgres)
POSTGRES_DATABASE=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_URL_NO_SSL=
POSTGRES_USER=

# for signed cookie
COOKIE_SECRET=

# for OAuth token encryption (AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=

# for cron job
CRON_SECRET=

## Enable @vercel/flags at all times in the development environment
DEVELOPER_FLAG="true"

# @vercel/flags API Reference https://vercel.com/docs/workflow-collaboration/feature-flags/vercel-flags
# @see https://vercel.com/docs/workflow-collaboration/feature-flags/supporting-feature-flags#flags_secret-environment-variable
FLAGS_SECRET=

# Google Tag Manager https://tagmanager.google.com/
# @see https://support.google.com/tagmanager/answer/6102821
NEXT_PUBLIC_GTM_ID=

# Langfuse https://langfuse.com/
# @see https://langfuse.com/docs/get-started
LANGFUSE_BASEURL=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Sentry https://sentry.io/
# @see https://docs.sentry.io/cli/configuration/
# Set SENTRY_ENABLE=true to enable Sentry (server/edge/build)
# Set NEXT_PUBLIC_SENTRY_ENABLE=true to enable Sentry on the client
SENTRY_ENABLE=
NEXT_PUBLIC_SENTRY_ENABLE=
SENTRY_AUTH_TOKEN=

# Stripe https://stripe.com/
# @see https://docs.stripe.com/keys
STRIPE_SECRET_KEY=
STRIPE_PRO_PLAN_PRICE_ID=
# Stripe Pricing Plans v2 (preview API)
STRIPE_PRO_PRICING_PLAN_ID=
STRIPE_PRO_LICENSE_FEE_COMPONENT_ID=
STRIPE_V2_WEBHOOK_SECRET=

# Supabase https://supabase.com/
# @see https://supabase.com/docs/guides/getting-started/tutorials/with-nextjs#initialize-a-nextjs-app
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=

# SMTP Email Configuration
SMTP_FROM=
SMTP_FROM_NAME=
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=

# Email Debug Mode (set "true" to skip sending emails and show debug output)
SEND_EMAIL_DEBUG=1

# Internal User Configuration
# Email domain for internal users (e.g., example.com)
# When set, users with matching email domain are treated as internal users.
# Note: Only exact domain matches are considered (subdomains are not matched).
INTERNAL_USER_EMAIL_DOMAIN=
